name: glpi

services:
  db:
    image: "mariadb"
    restart: "unless-stopped"
    volumes:
      - glpi_db_data:/var/lib/mysql
    environment:
      MYSQL_RANDOM_ROOT_PASSWORD: "yes"
      MYSQL_DATABASE: ${GLPI_DB_NAME}
      MYSQL_USER: ${GLPI_DB_USER}
      MYSQL_PASSWORD: ${GLPI_DB_PASSWORD}
    ports:
      - "3306:3306"


volumes:
  glpi_db_data:
